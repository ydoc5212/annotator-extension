{
  "manifest_version": 3,
  "name": "Web Annotator v2",
  "version": "1.0",
  "description": "Interaction layer for the web",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Web Annotator v2"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.tsx"]
    }
  ],
  "background": {
    "service_worker": "src/background.ts"
  }
}
